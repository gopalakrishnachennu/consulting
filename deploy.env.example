# Copy to .env.deploy (gitignored) and set your server.
# deploy.sh sources .env.deploy automatically.

DEPLOY_HOST=your.server.ip.or.hostname
DEPLOY_USER=root
DEPLOY_PATH=/opt/consulting
DEPLOY_BRANCH=main

# Optional
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519
# DEPLOY_SLEEP=5
# ALLOW_DIRTY=1
# REQUIRE_MAIN=0
