##############################################################################
# Local Harvesting Agent — Environment Template
#
# Copy to .env.harvester and fill in your values:
#   cp .env.harvester.example .env.harvester
##############################################################################

# Always use the minimal harvester settings (strips web-only apps)
DJANGO_SETTINGS_MODULE=config.settings_local_harvester

# Any random value — this instance never serves web traffic
SECRET_KEY=local-harvester-change-me

##############################################################################
# Pick ONE mode — comment out the other
##############################################################################

# ─── MODE A: DIRECT (recommended) ────────────────────────────────────────────
# Local harvester writes straight into prod's PostgreSQL.
# Get this URL from your prod server's .env (or via SSH tunnel: see docs).
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
DATABASE_URL=postgres://consulting:YOUR_DB_PASSWORD@your-prod-host.com:5432/consulting

# ─── MODE B: PUSH (when prod DB is not directly reachable) ───────────────────
# Harvest offline, push enriched RawJobs via HTTPS API.
# PUSH_TOKEN must match HARVEST_PUSH_SECRET on the prod server.
# Generate a secret with:  python -c "import secrets; print(secrets.token_hex(32))"
#
# DATABASE_URL=sqlite:///local_harvest.db
# PUSH_URL=https://chennu.co
# PUSH_TOKEN=paste-your-64-char-hex-secret-here

##############################################################################
# Tuning (optional — defaults are good for most machines)
##############################################################################

# Jarvis JD-backfill concurrency — local machines can go much higher than prod
JARVIS_HTTP_MAX_GLOBAL=500
JARVIS_HTTP_MAX_PER_HOST=20

# Delay between JD-backfill jobs (seconds). Lower = faster. 0.02 = ~50/s max.
HARVEST_BACKFILL_INTER_JOB_DELAY_SEC=0.02

# Celery runs synchronously (no Redis/broker needed for the local agent)
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
