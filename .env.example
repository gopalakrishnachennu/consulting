# ─────────────────────────────────────────────────────────────────────────────
# GoCareers — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgres://postgres:postgres@db:5432/gocareers
# SQLite (local dev only)
# DATABASE_URL=sqlite:///db.sqlite3

# ── Redis ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
# Local dev:
# CELERY_BROKER_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
# Use 'django-db' to store results in PostgreSQL (recommended for production)
# Use 'redis://redis:6379/1' for Redis-backed results (faster but not persistent)
CELERY_RESULT_BACKEND=django-db

# CRITICAL: Must be False in production. True = tasks run synchronously (no background workers)
CELERY_TASK_ALWAYS_EAGER=False

# Number of parallel task workers (increase for high-load servers)
CELERY_WORKER_CONCURRENCY=2

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=GoCareers <noreply@gocareers.com>

# ── AI / OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key...

# ── Security (production) ─────────────────────────────────────────────────────
# Uncomment in production:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Django Settings Module ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings

# ── Python Path (required when running from /app root) ───────────────────────
PYTHONPATH=/app/apps
